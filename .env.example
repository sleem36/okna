# Копируйте в .env.local и заполните значения.
# Без этих переменных форма «Оставить заявку» вернёт ошибку.

# SMTP (пример для Beget)
SMTP_HOST=smtp.beget.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=info@yourdomain.ru
SMTP_PASSWORD=your-password
# или SMTP_PASS=your-password

# От кого в письме (по умолчанию — SMTP_USER)
SMTP_FROM=info@yourdomain.ru
# или CONTACT_FROM=info@yourdomain.ru

# Куда присылать заявки
CONTACT_TO=your-inbox@list.ru

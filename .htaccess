# Basic Auth: статика /_next/ — без пароля (иначе ChunkLoadError), остальное — с паролем
SetEnvIf Request_URI "^/_next/" let_static_through
AuthType Basic
AuthName "Restricted Access"
AuthUserFile /home/c/c59840wv/test/public_html/.htpasswd
<RequireAny>
  Require env=let_static_through
  Require valid-user
</RequireAny>

PassengerNodejs /home/c/c59840wv/.local/bin/node
PassengerAppRoot /home/c/c59840wv/test/public_html
PassengerAppType node
PassengerStartupFile app.js
PassengerAppEnv production
PassengerFriendlyErrorPages on

# Не искать файлы на диске — все запросы отдавать Node (Passenger)
Options -MultiViews
